{
  "name": "trust-questionnaire",
  "private": true,
  "type": "module",
  "scripts": {
    "serve:static": "python3 -m http.server 4173 --bind 127.0.0.1",
    "serve:app": "node --env-file=.env server/app.js",
    "dev:app": "node --watch --env-file=.env server/app.js",
    "validate:html": "html-validate trust-framework.html",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium firefox",
    "format": "prettier --write 'static/js/**/*.js' 'static/css/**/*.css'",
    "format:check": "prettier --check 'static/js/**/*.js' 'static/css/**/*.css'",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run validate:html && vitest run && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "html-validate": "^9.3.0",
    "prettier": "^3.5.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "fastify": "^5.8.4",
    "jszip": "^3.10.1",
    "pg": "^8.20.0"
  }
}
